{
  "ui": {
    "title": "Matt's Work App",
    "icon": "arrow-through-heart-fill"
  },
  "auth": [
    {
      "name": "red",
      "display": "Red Provider",
      "configId": "red",
      "authority": "https://localhost:4000/red",
      "redirectUrl": "http://localhost:4200/auth/callback/red",
      "clientId": "work-app",
      "scope": "openid profile email offline_access",
      "responseType": "code",
      "silentRenew": true,
      "useRefreshToken": true,
      "renewTimeBeforeTokenExpiresInSeconds": 30,
      "unauthorizedRoute": "/auth",
      "secureRoutes": [
        "https://localhost:3000/api/"
      ],
      "authWellknownEndpoints": {
        "issuer": "https://localhost:4000/red",
        "jwksUri": "https://localhost:4000/red/.well-known/jwks.json",
        "authorizationEndpoint": "https://localhost:4000/red/authorize",
        "tokenEndpoint": "https://localhost:4000/red/token",
        "userinfoEndpoint": "https://localhost:4000/red/userinfo"
      }
    },
